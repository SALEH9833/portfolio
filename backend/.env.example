# =============================================================================
# Portfolio Backend — .env.example
# Copie ce fichier vers .env et remplis les vraies valeurs.
# Pour le déploiement Railway: copier ces variables dans Railway → Variables.
# =============================================================================

# ---- Serveur ----
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ---- Base de données PostgreSQL ----
# En local : valeurs ci-dessous
# Sur Railway : utilise DATABASE_URL fourni automatiquement (laisser ces lignes vides)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portfolio
DB_USER=postgres
DB_PASSWORD=

# ---- Sécurité ----
# Génère une nouvelle chaîne aléatoire pour la production :
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-random-96-chars-string
JWT_EXPIRES_IN=7d

# ---- Admin ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ---- Email Gmail (formulaire contact + vérification compte) ----
# App Password Gmail : https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=ton.email@gmail.com
EMAIL_PASS=
EMAIL_TO=ton.email@gmail.com

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CONTACT_LIMIT_WINDOW_MS=3600000
CONTACT_LIMIT_MAX=5

# ---- Anthropic (chatbot IA) ----
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---- PayPal (optionnel — paiement automatique) ----
# Si vide, paiement reste manuel via PayPal.me
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
